# starLog 环境变量配置模板
# 复制此文件为 .env.local 并填入实际值

# ==================== 数据库配置 ====================
DATABASE_URL="postgresql://starlog:starlog123@localhost:5432/starlog?connection_limit=10"

# ==================== Redis 配置 ====================
REDIS_URL="redis://localhost:6379"

# ==================== Next.js 配置 ====================
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:8081"

# ==================== Umami 分析配置 ====================
# 获取方式：登录 Umami 后台 → 网站设置 → 复制网站 ID 和 API Key
NEXT_PUBLIC_UMAMI_API_URL="https://umami.starlog.dev"
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""  # 必填：Umami 网站 ID
NEXT_PUBLIC_UMAMI_API_KEY=""     # 必填：Umami API Key

# ==================== 飞书通知配置 ====================
# 获取方式：飞书群 → 设置 → 群机器人 → 创建机器人 → 复制 Webhook
FEISHU_WEBHOOK=""  # 可选：飞书 Webhook 地址

# ==================== 金融 API 配置 ====================
FINANCE_API_KEY=""  # 可选：金融数据 API Key
TUSHARE_TOKEN=""    # 可选：Tushare 数据 Token

# ==================== 其他配置 ====================
NODE_ENV="production"
LOG_LEVEL="info"
