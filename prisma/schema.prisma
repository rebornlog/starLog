// Prisma Schema for starLog

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 博客文章
model Post {
  id          String   @id @default(cuid())
  slug        String   @unique  // URL 路径，如：qps-optimization-guide
  title       String
  summary     String?  @db.Text
  content     String   @db.Text  // Markdown 全文
  excerpt     String?  @db.Text  // 摘要，用于列表页
  coverImage  String?  // 封面图 URL
  
  // 分类和标签
  category    String   @default("tech")  // tech, finance, fengshui, business
  tags        String[]
  
  // 发布状态
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  
  // 统计数据
  viewCount   Int      @default(0)
  likeCount   Int      @default(0)
  commentCount Int     @default(0)
  
  // 阅读时间（分钟）
  readingTime Int      @default(5)
  
  // SEO
  metaTitle   String?
  metaDesc    String?
  keywords    String[]
  
  // 作者
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  
  // 时间戳
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // 索引 - 支持高效查询和全文检索
  @@index([category])
  @@index([tags])
  @@index([isPublished, publishedAt])
  @@index([authorId])
  @@index([slug])
}

/// 用户（作者）
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  avatar    String?
  bio       String?  @db.Text
  website   String?
  
  // 关联文章
  posts     Post[]
  
  // 时间戳
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([email])
}

/// 知识库文档
model Document {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  summary     String?
  content     String   @db.Text
  excerpt     String?
  coverImage  String?
  tags        String[]
  category    String?
  isPublished Boolean  @default(false)
  viewCount   Int      @default(0)
  downloadCount Int    @default(0)
  
  // 文件信息
  filePath    String?
  fileSize    Int?     // bytes
  fileType    String?  // mime type
  
  // SEO
  metaTitle   String?
  metaDesc    String?
  keywords    String[]
  
  // 时间戳
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  publishedAt DateTime?
  
  // 全文搜索索引
  @@index([title])
  @@index([tags])
  @@index([category])
  @@index([isPublished])
}

/// 金融数据缓存
model StockData {
  id        String   @id @default(cuid())
  symbol    String
  market    String   @default("US")  // US, CN, CRYPTO
  
  // 实时数据
  price     Float?
  change    Float?
  changePercent Float?
  high      Float?
  low       Float?
  open      Float?
  previousClose Float?
  volume    BigInt?
  
  // 时间序列数据 (JSON 存储 K 线)
  candles   Json?    // [{t, o, h, l, c, v}]
  
  // 更新时间
  updatedAt DateTime @updatedAt
  
  @@unique([symbol, market])
  @@index([symbol])
  @@index([market])
}

/// 技术分析指标
model TechnicalIndicator {
  id        String   @id @default(cuid())
  symbol    String
  type      String   // MA, MACD, RSI, Bollinger
  period    String   // 1d, 1h, 15m
  parameters Json    // { period: 20, etc }
  values    Json     // 指标值
  calculatedAt DateTime @default(now())
  
  @@index([symbol, type])
}

/// 用户收藏/书签
model Bookmark {
  id        String   @id @default(cuid())
  title     String
  url       String
  tags      String[]
  notes     String?
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  
  @@index([tags])
}

/// 系统配置
model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
