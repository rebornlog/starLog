generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 博客文章
model Post {
  id           String    @id @default(cuid())
  slug         String    @unique
  title        String
  summary      String?
  content      String
  excerpt      String?
  coverImage   String?
  category     String    @default("tech")
  tags         String[]
  isPublished  Boolean   @default(false)
  publishedAt  DateTime?
  viewCount    Int       @default(0)
  likeCount    Int       @default(0)
  commentCount Int       @default(0)
  readingTime  Int       @default(5)
  metaTitle    String?
  metaDesc     String?
  keywords     String[]
  authorId     String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  author       User      @relation(fields: [authorId], references: [id])

  @@index([category])
  @@index([tags])
  @@index([isPublished, publishedAt])
  @@index([authorId])
  @@index([slug])
}

/// 用户（作者）
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  avatar    String?
  bio       String?
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]

  @@index([email])
}

/// 知识库文档
model Document {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  summary       String?
  content       String
  excerpt       String?
  coverImage    String?
  tags          String[]
  category      String?
  isPublished   Boolean   @default(false)
  viewCount     Int       @default(0)
  downloadCount Int       @default(0)
  filePath      String?
  fileSize      Int?
  fileType      String?
  metaTitle     String?
  metaDesc      String?
  keywords      String[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  publishedAt   DateTime?

  @@index([title])
  @@index([tags])
  @@index([category])
  @@index([isPublished])
}

/// 金融数据缓存
model StockData {
  id            String   @id @default(cuid())
  symbol        String
  market        String   @default("US")
  price         Float?
  change        Float?
  changePercent Float?
  high          Float?
  low           Float?
  open          Float?
  previousClose Float?
  volume        BigInt?
  candles       Json?
  updatedAt     DateTime @updatedAt

  @@unique([symbol, market])
  @@index([symbol])
  @@index([market])
}

/// 技术分析指标
model TechnicalIndicator {
  id           String   @id @default(cuid())
  symbol       String
  type         String
  period       String
  parameters   Json
  values       Json
  calculatedAt DateTime @default(now())

  @@index([symbol, type])
}

/// 用户收藏/书签
model Bookmark {
  id        String   @id @default(cuid())
  title     String
  url       String
  tags      String[]
  notes     String?
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tags])
}

/// 系统配置
model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
